// This project was developed with assistance from AI tools.
//
// OpenClaw configuration -- hardened for sandbox deployment.
// JSON5 format (comments and trailing commas allowed).
// See docs/threat-model.md for rationale behind each setting.
// Schema reference: https://docs.openclaw.ai/gateway/configuration-reference.md
{
  // Secrets read directly from files rendered by Vault via fetch-secrets.sh.
  // No env vars, no Podman secrets -- files on tmpfs only.
  "secrets": {
    "providers": {
      "anthropic-key": {
        "source": "file",
        "path": "/secrets/anthropic",
        "mode": "singleValue",
      },
      "gateway-token": {
        "source": "file",
        "path": "/secrets/gateway_token",
        "mode": "singleValue",
      },
      "brave-search-key": {
        "source": "file",
        "path": "/secrets/brave_search",
        "mode": "singleValue",
      },
    },
  },

  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": { "source": "file", "provider": "gateway-token", "id": "value" },
    },
    "controlUi": {
      "enabled": true,
      "allowedOrigins": [
        "https://__LAN_IP__:18790",
        "https://__TAILSCALE_DESKTOP__:18790",
      ],
    },
  },

  "models": {
    "providers": {
      "anthropic": {
        "baseUrl": "https://api.anthropic.com",
        "apiKey": { "source": "file", "provider": "anthropic-key", "id": "value" },
        "api": "anthropic-messages",
        "models": [
          {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6",
            "api": "anthropic-messages",
            "reasoning": false,
            "input": ["text", "image"],
          },
        ],
      },
    },
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6",
      },
      // Host-absolute path so sandbox volume mounts resolve through the Podman socket.
      "workspace": "${OPENCLAW_WORKSPACE}",
      "sandbox": {
        "mode": "all",
        "scope": "session",
        "workspaceAccess": "rw",
        "docker": {
          "image": "openclaw-sandbox:bookworm-slim",
          "network": "none",
          "capDrop": ["ALL"],
          // UID 0 in rootless Podman = host UID 1000 (unprivileged).
          // Matches workspace owner so sandbox can write. All capabilities
          // are dropped, so root has no actual privileges inside the sandbox.
          "user": "0:0",
          "tmpfs": ["/tmp:noexec,nosuid,nodev", "/var/tmp:noexec,nosuid,nodev"],
        },
      },
      "timeoutSeconds": 600,
    },
  },

  "tools": {
    // Use "full" profile + deny list instead of "coding" + allow.
    // tools.allow replaces the profile in v2026.3.11 (despite docs
    // saying it extends). This approach avoids that bug.
    "profile": "full",
    "deny": [
      "process",
      "group:ui",
      "group:messaging",
      "group:nodes",
      "gateway",
      "sessions_spawn",
      "sessions_send",
    ],
    "exec": {
      "security": "allowlist",
      "ask": "always",
      "safeBins": ["ls"],
      "safeBinProfiles": { "ls": {} },
    },
    "fs": {
      "workspaceOnly": true,
    },
    // Override default sandbox tool policy to add non-default tools.
    // Setting allow replaces the default list, so we must include
    // all default sandbox tools plus additions.
    "sandbox": {
      "tools": {
        "allow": [
          // Default sandbox tools
          "exec", "process", "read", "write", "edit", "apply_patch",
          "image", "subagents", "session_status",
          "sessions_list", "sessions_history", "sessions_send", "sessions_spawn",
          // Added tools
          "cron", "web_search", "web_fetch",
        ],
        "deny": ["browser", "canvas", "nodes", "gateway"],
      },
    },
    "elevated": {
      "enabled": false,
    },
    "web": {
      "search": {
        "enabled": true,
        "apiKey": { "source": "file", "provider": "brave-search-key", "id": "value" },
      },
      "fetch": {
        "enabled": true,
      },
    },
  },

  // No messaging channels
  "channels": {                                                                                                                                                 
    "signal": {                                                                                                                                                   
      "enabled": false,
      "account": "__SIGNAL_ACCOUNT__",
      "cliPath": "signal-cli",
      "dmPolicy": "pairing",
      "allowFrom": ["__SIGNAL_ALLOW__"],                                                                                                                                
    },                                                                                                                                                          
  },

  "session": {
    "dmScope": "main",
  },

  "logging": {
    "redactSensitive": "tools",
  },
}
