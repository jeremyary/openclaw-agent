# This project was developed with assistance from AI tools.
#
# Copy to .env and fill in your values.
# .env is gitignored and never committed.

# Vault connection
VAULT_ADDR=https://your-vault-server:8200
VAULT_CACERT=/path/to/vault/ca-cert.pem

# AppRole credentials file (contains VAULT_ROLE_ID and VAULT_SECRET_ID)
APPROLE_CREDS=/path/to/approle/openclaw.env

# LAN IP for Control UI CORS (the IP your browser connects from)
OPENCLAW_LAN_IP=127.0.0.1
